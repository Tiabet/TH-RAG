# TH-RAG Configuration Template
# Copy this file to .env and replace placeholder values as needed.

OPENAI_API_KEY=your_openai_api_key_here

# Models
DEFAULT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
EVAL_MODEL=gpt-4o-mini

# Generation
TEMPERATURE=0.5
MAX_TOKENS_RESPONSE=2000
ANSWER_TEMPERATURE=0.3
ANSWER_MAX_TOKENS=1000
EVAL_TEMPERATURE=0.1

# Text chunking
MAX_TOKENS=3000
OVERLAP=300
ALT_MAX_TOKENS=1200
ALT_OVERLAP=100
MAX_WORKERS=10

# Topic and subtopic selection
TOPIC_CHOICE_MIN=5
TOPIC_CHOICE_MAX=10
SUBTOPIC_CHOICE_MIN=10
SUBTOPIC_CHOICE_MAX=25
MAX_RETRIES=10
RETRY_BACKOFF=0.2

# Retrieval
TOP_K1=50
TOP_K2=10
TOP_K1_LONG=25
TOP_K2_LONG=5
EMBEDDING_TOP_K=5
OVERRETRIEVE_FACTOR=5
MAX_CONTEXT_LENGTH=4000

# System
LOG_LEVEL=INFO
LOG_FILE=thrag.log
BATCH_SIZE=32
TIMEOUT_SECONDS=30
ENABLE_CACHE=true
CACHE_TTL=3600
